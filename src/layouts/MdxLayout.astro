---
import Layout from './Layout.astro';
import 'src/css/light-dark.css';

interface Props {
	frontmatter?: {
		title: string;
		overview?: string;
	};
	title?: string;
}
const { frontmatter } = Astro.props;
const title = frontmatter?.title ?? Astro.props.title ?? '';
const base = import.meta.env.MODE === 'production' ? '/games-uner' : '';
if (!title) {
	console.log('Title not set for ' + Astro.url.pathname);
}
---

<Layout {title}>
	<slot name="head" slot="head" />
	<slot name="head2" slot="head2" />
	<header>
		<a href="javascript:history.back()">⮌ Atrás</a>
		{frontmatter?.overview && <a href={frontmatter.overview}> | Descripción</a>} | <a
			data-astro-reload
			href={`${base}/`}>Inicio</a
		>
	</header>
	<main>
		<slot />
	</main>
	<footer>
		<a href="javascript:history.back()">⮌ Atrás</a> |
		{frontmatter?.overview && <a href={frontmatter.overview}>Descripción |</a>}
		<a href=".">Volver arriba</a>
	</footer>
</Layout>

<style is:global>
	::view-transition-group(*) {
		animation-duration: 0.66s;
	}

	a {
		color: var(--vtbot-global-accent);
		text-decoration: dotted underline;
	}
	h1,
	h2,
	h3,
	h4 {
		& a {
			text-decoration: none;
		}
	}
	h1,
	h1 a {
		color: var(--vtbot-color);
	}
	header {
		position: sticky;
		top: 0;
		background: rgba(13, 17, 23, 0.85);
		backdrop-filter: blur(14px);
		border-bottom: 1px solid rgba(255, 255, 255, 0.07);
		z-index: 100;
		padding: 0.7rem 1.5rem;
		display: flex;
		gap: 1.2rem;
		align-items: center;
		font-size: 0.9rem;
		font-family: 'Space Grotesk', sans-serif;
	}

	footer {
		border-top: 1px solid rgba(255, 255, 255, 0.07);
		padding: 1rem 1.5rem;
		text-align: center;
		font-size: 0.85rem;
		color: #8b949e;
		background: rgba(13, 17, 23, 0.5);
		font-family: 'Space Grotesk', sans-serif;
	}

	footer a,
	header a {
		text-decoration: none;
		color: #4cc9f0;
		font-weight: 600;
		transition: color 0.2s;
	}

	footer a:hover,
	header a:hover {
		color: #a8e8f5;
	}

	main {
		padding: 2rem 3rem;
		color: var(--vtbot-color);
		max-width: 860px;
		margin: 0 auto;
	}

	:root {
		font-family: 'Space Grotesk', sans-serif;
	}
	code {
		font-size: 1rem;
		color: var(--vtbot-accent);
	}
	table code {
		font-size: 0.8rem;
		color: var(--vtbot-accent);
	}

	#contents + ul {
		font-family: sans-serif;
		line-height: 1.3;
		background-color: var(--vtbot-table-background-color);
		border-radius: 8px;
		border: 1px dashed #ccc;
		box-shadow: 2px 2px 2px #5659;
	}
	#contents + ul {
		padding: 1em;
	}
	#contents + ul ul,
	#contents + ul ul ul {
		margin: 0 0;
		padding: 0em 1em;
	}
	#contents + ul,
	#contents + ul li,
	#contents + ul ul li {
		list-style: none;
	}

	#contents + ul a {
		text-decoration: none;
	}
	#contents + ul li::before {
		content: '↪︎ ';
	}

	img {
		margin: auto;
		display: block;
		max-width: 100%;
		height: auto;
		border-radius: 6px;
		border: 1px solid #cccc;
		box-shadow: 2px 2px 2px #cccc;
	}

	#vtbot-loading-indicator img {
		border: 0pt;
		box-shadow: none;
	}

	pre {
		padding: 1rem;
		border: 1px solid #888;
		border-radius: 6px;
		tab-size: 2;
		overflow: scroll;
	}
	td {
		background-color: var(--vtbot-table-background-color);
		font-family: sans-serif;
		font-size: 0.8rem;
		padding: 0.5rem;
	}
	h2,
	h3 {
		margin-top: 2rem;
		margin-bottom: 0.5rem;
		color: var(--vtbot-global-accent);
	}
	body {
		max-width: 840px;
		padding: 3ex;
		margin: 0 auto;
	}
	p {
		hyphens: auto;
	}
</style>
