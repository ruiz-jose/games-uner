---
import { Image } from 'astro:assets';
import Layout from 'src/layouts/Layout.astro';
import logo from 'src/assets/logo.png';
import bot from 'astro-vtbot/assets/bag-of-tricks.svg';
const base = import.meta.env.MODE === 'production' ? '/games-uner' : '';
//const base = import.meta.env.MODE === 'production' ? '' : '';
---

<Layout title="Bienvenidos a la colección de juegos para aprender computación">
	<script slot="head" type="application/ld+json" data-vtbot-linter="ignore" is:inline>
		{
			"@context": "https://schema.org",
			"@type": "WebSite",
			"name": "Colección de juegos para aprender computación",
			"alternateName": ["Juegos computación", "Games UNER"],
			"url": "https://ruiz-jose.github.io/games-uner/"
		}
	</script>

	<meta slot="head" property="og:site_name" content="Juegos para aprender computación" />
	<meta
		slot="head"
		property="og:title"
		content="Bienvenidos a la colección de juegos para aprender computación"
	/>
	<meta
		slot="head"
		name="description"
		content="Colección de juegos interactivos para aprender computación: binario, decimal y más."
	/>
	<meta slot="head" property="twitter:card" content="summary_large_image" />
	<meta slot="head" name="robots" content="index, follow" />
	<meta slot="head" property="og:type" content="website" />
	<meta slot="head" property="og:url" content="https://ruiz-jose.github.io/games-uner/" />
	<meta
		slot="head"
		property="og:description"
		content="Colección de juegos interactivos para aprender computación: binario, decimal y más."
	/>
	<meta slot="head" property="og:locale" content="es_AR" />

	<Image id="logo" src={logo} alt="Logo Fcad" transition:animate="slide" transition:name="logo" />

	<h2 class="massive">
		Bienvenidos a la<br />
		<span class="grad">colección de juegos <Image transition:name="bot" id="bot" src={bot} alt="Colección de recursos" /></span>
		<br />para aprender computación
	</h2>
</Layout>

<a href={`${base}/demos/`} transition:name="demos">Ver juegos →</a>

<div class="github-link">
	⭐ <a href="https://github.com/ruiz-jose/games-uner">games-uner</a> en GitHub
</div>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700;800&display=swap');

	html {
		background: #0d1117;
		overflow: hidden;
	}

	html::before {
		content: '';
		position: fixed;
		inset: 0;
		background:
			radial-gradient(ellipse at 15% 55%, rgba(114, 9, 183, 0.22) 0%, transparent 55%),
			radial-gradient(ellipse at 85% 20%, rgba(67, 97, 238, 0.22) 0%, transparent 55%),
			radial-gradient(ellipse at 50% 90%, rgba(247, 37, 133, 0.12) 0%, transparent 55%),
			linear-gradient(135deg, #0d1117 0%, #12122a 100%);
		z-index: -1;
		pointer-events: none;
	}

	body {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		height: 100vh;
		margin: 0;
		padding: 2rem;
		gap: 2rem;
		font-family: 'Space Grotesk', Arial, sans-serif;
	}

	#logo {
		position: fixed;
		top: 1.5rem;
		right: 1.5rem;
		left: auto;
		bottom: auto;
		width: clamp(50px, 7vw, 85px);
		height: auto;
		opacity: 0.7;
		z-index: 10;
		transition: opacity 0.3s ease;
	}
	#logo:hover { opacity: 1; }

	.massive {
		color: #e6edf3;
		padding: 0;
		font-size: clamp(1.6rem, 4.5vw, 3.8rem);
		font-weight: 800;
		font-family: 'Space Grotesk', Arial, sans-serif;
		text-shadow: none;
		line-height: 1.3;
		text-align: center;
		margin: 0;
	}

	.grad {
		background-image: linear-gradient(135deg, #4cc9f0 0%, #7209b7 50%, #f72585 100%);
		background-size: 200% auto;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		-moz-background-clip: text;
		-moz-text-fill-color: transparent;
		background-clip: text;
		animation: gradShift 5s ease-in-out infinite;
	}

	@keyframes gradShift {
		0%, 100% { background-position: 0% center; }
		50% { background-position: 100% center; }
	}

	#bot {
		height: 0.85em;
		width: auto;
		display: inline-block;
		vertical-align: middle;
		margin-left: 0.2em;
	}

	body > a {
		font-family: 'Space Grotesk', sans-serif;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: clamp(1rem, 2.5vw, 1.25rem);
		font-weight: 700;
		background: linear-gradient(135deg, #4361ee, #7209b7);
		color: white;
		border-radius: 50px;
		padding: 0.75em 2.5em;
		margin: 0;
		text-decoration: none;
		width: auto;
		letter-spacing: 0.02em;
		box-shadow: 0 0 30px rgba(67, 97, 238, 0.45), 0 4px 20px rgba(0, 0, 0, 0.4);
		text-shadow: none;
		transition: all 0.3s ease;
	}

	body > a:hover {
		transform: translateY(-3px);
		box-shadow: 0 0 55px rgba(67, 97, 238, 0.65), 0 8px 30px rgba(0, 0, 0, 0.4);
	}

	.github-link {
		font-family: 'Space Grotesk', sans-serif;
		font-size: clamp(0.75rem, 1.5vw, 0.9rem);
		color: rgba(255, 255, 255, 0.45);
		position: fixed;
		bottom: 1.5rem;
		left: 50%;
		transform: translateX(-50%);
		white-space: nowrap;
		z-index: 10;
		transition: color 0.3s;
	}

	.github-link a {
		color: #4cc9f0;
		text-decoration: none;
		font-weight: 600;
		transition: color 0.3s;
	}

	.github-link a:hover { color: #a8e8f5; }

	::view-transition-new(root),
	::view-transition-old(root) {
		animation-duration: 0.5s;
	}
	::view-transition-new(dtb) {
		animation: 1s ease-out both from-bottom;
	}
	@keyframes from-bottom {
		from { transform: translateY(100%); }
	}
</style>
