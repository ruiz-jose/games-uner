---
import MdxLayout from '../layouts/MdxLayout.astro';
import Card from '../components/Card.astro';
import Content from 'src/mdx/demos.mdx';
const base = import.meta.env.MODE === 'production' ? '/games-uner' : '';
//const base = import.meta.env.MODE === 'production' ? '' : '';
---

<MdxLayout title="Juegos">
	<h1>
		<span transition:name="demos">Colección de</span><br />
		<span class="text-gradient">juegos</span> para aprender computación
	</h1>

	<Content />
	<ul role="list" class="link-card-grid" transition:name="bot">
		<Card
			what="Binario a Decimal"
			href={`${base}/binario`}
			title="Binario a Decimal"
			icon="🔢"
			body="Practica la conversión entre números binarios y decimales de forma interactiva."
			reload
		/>
		<Card
			what="Juego de 4 Bits"
			href={`${base}/4bits`}
			title="Juego de 4 Bits"
			icon="💡"
			body="Enciende las luces correctas para representar números binarios en 4 bits."
			reload
		/>
		<Card
			what="Matriz Binaria"
			href={`${base}/matriz`}
			title="Matriz Binaria"
			icon="🧮"
			body="Completa la cuadrícula binaria para que las sumas de filas y columnas sean correctas."
			reload
		/>
		<Card
			what="Juego Binario de Cisco"
			href="https://learningcontent.cisco.com/games/binary/index.html"
			title="Juego Binario Cisco"
			icon="🎮"
			body="Explora el juego interactivo de Cisco para aprender sobre números binarios."
			reload
		/>
		<Card
			what="Virtual Mechanical Adder"
			href="https://leloctai.com/mechanicalAdder/"
			title="Sumadora Mecánica"
			icon="⚙️"
			body="Máquina sumadora binaria basada en el diseño de Matthias Wandel. ¡El toque analógico en 3D es fascinante!"
			reload
		/>
		<Card
			what="Binary Login"
			href="https://binary.loicviennois.com/login"
			title="Binary Login"
			icon="🔐"
			body="Aprende sobre números binarios y su aplicación en sistemas de autenticación."
			reload
		/>
	</ul>
</MdxLayout>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700;800&display=swap');

	::view-transition-old(demos) {
		opacity: 0;
	}
	::view-transition-group(root) {
		animation-duration: 1s;
	}
	::view-transition-old(dtb) {
		animation: to-bottom 1s both;
	}
	@keyframes to-bottom {
		to { transform: translateY(100%); }
	}

	:root {
		--accent: 76, 201, 240;
		--accent-gradient: linear-gradient(135deg, #4361ee, #7209b7);
	}

	html {
		font-family: 'Space Grotesk', sans-serif;
	}
</style>

<style>
	main {
		margin: auto;
		padding: 1.5rem;
	}

	h1 {
		font-size: clamp(2rem, 5vw, 3.2rem);
		font-weight: 800;
		margin: 0 0 0.5rem;
		line-height: 1.2;
		font-family: 'Space Grotesk', sans-serif;
	}

	html body {
		max-width: 90%;
	}

	.text-gradient {
		background-image: linear-gradient(135deg, #4cc9f0, #7209b7, #f72585);
		background-size: 200% auto;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		animation: gradShift 5s ease-in-out infinite;
	}

	@keyframes gradShift {
		0%, 100% { background-position: 0% center; }
		50% { background-position: 100% center; }
	}

	.link-card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.2rem;
		padding: 0;
		margin-top: 1.5rem;
	}
</style>
