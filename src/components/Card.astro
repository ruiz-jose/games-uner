---
export interface Props {
	name?: string;
	title: string;
	body?: string;
	href: string;
	icon: string;
	iconStyle?: string;
	what: string;
	reload?: boolean;
}

const { name, href, title, body, icon, iconStyle = '', what, reload } = Astro.props;
const hrefProps = reload ? { 'data-astro-reload': true } : {};
---

<li class="link-card">
	<a href={href} {...hrefProps}>
		<span class="card-icon">
			{
				name ? (
					<span style={`view-transition-name: ${name + '-2'}; display:inline-block; ${iconStyle}`}>
						{icon}
					</span>
				) : (
					<span style={iconStyle}>{icon}</span>
				)
			}
		</span>
		<div class="card-body">
			<h2>
				{
					name ? (
						<span style={`view-transition-name: ${name + '-1'}; display:inline-block`}>{title}</span>
					) : (
						`${title}`
					)
				}
				<span class="arrow">&nbsp;→</span>
			</h2>
			<p>
				{body}
				{
					name ? (
						<div style={`view-transition-name: ${name + '-3'};`}>
							<slot />
						</div>
					) : (
						<slot />
					)
				}
			</p>
		</div>
	</a>
</li>

<style>
	.link-card {
		list-style: none;
		display: flex;
		padding: 1px;
		background: linear-gradient(135deg, rgba(67, 97, 238, 0.35), rgba(114, 9, 183, 0.35));
		border-radius: 14px;
		transition: all 0.35s ease;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.35);
	}

	.link-card > a {
		width: 100%;
		text-decoration: none;
		line-height: 1.5;
		padding: 1.2rem 1.4rem;
		border-radius: 13px;
		background: rgba(13, 17, 23, 0.88);
		backdrop-filter: blur(12px);
		color: #e6edf3;
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		transition: background 0.35s ease;
	}

	.card-icon {
		font-size: 2.4rem;
		line-height: 1;
		flex-shrink: 0;
		margin-top: 0.1rem;
	}

	.card-body {
		flex: 1;
		min-width: 0;
	}

	h2 {
		margin: 0 0 0.3rem;
		font-size: 1.1rem;
		font-weight: 700;
		color: #e6edf3;
		transition: color 0.3s ease;
		font-family: 'Space Grotesk', sans-serif;
	}

	.arrow {
		color: #4cc9f0;
		opacity: 0;
		transition: opacity 0.3s ease, transform 0.3s ease;
		display: inline-block;
	}

	p {
		margin: 0;
		font-size: 0.875rem;
		color: #8b949e;
		line-height: 1.55;
		hyphens: auto;
	}

	.link-card:is(:hover, :focus-within) {
		background: linear-gradient(135deg, #4361ee, #7209b7);
		box-shadow: 0 0 35px rgba(67, 97, 238, 0.4), 0 8px 30px rgba(0, 0, 0, 0.4);
		transform: translateY(-4px);
	}

	.link-card:is(:hover, :focus-within) > a {
		background: rgba(13, 17, 23, 0.82);
	}

	.link-card:is(:hover, :focus-within) h2 {
		color: #4cc9f0;
	}

	.link-card:is(:hover, :focus-within) .arrow {
		opacity: 1;
		transform: translateX(3px);
	}
</style>
